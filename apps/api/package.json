{
  "name": "@mini-zapier/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "pnpm run prisma:generate && node ../../packages/shared/node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/main.js",
    "start:dev": "pnpm run build && node --env-file=.env dist/main.js",
    "start:prod": "node --env-file=.env dist/main.js",
    "prisma:generate": "prisma generate && node ./scripts/sync-prisma-client.cjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@mini-zapier/server-utils": "workspace:*",
    "@mini-zapier/shared": "workspace:*",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.2",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.9.0",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "prisma": "^6.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.0",
    "@types/pg": "^8.18.0"
  }
}
