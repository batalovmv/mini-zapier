{
  "name": "mini-zapier",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @mini-zapier/api run start:dev",
    "dev:worker": "pnpm --filter @mini-zapier/worker run start:dev",
    "dev:web": "pnpm --filter @mini-zapier/web run dev",
    "build:shared": "pnpm --filter @mini-zapier/shared run build",
    "build:api": "pnpm --filter @mini-zapier/api run build",
    "build:worker": "pnpm --filter @mini-zapier/worker run build",
    "build:web": "pnpm --filter @mini-zapier/web run build",
    "build": "pnpm build:shared && pnpm build:api && pnpm build:worker && pnpm build:web",
    "db:migrate": "pnpm --filter @mini-zapier/api run prisma:migrate",
    "db:generate": "pnpm --filter @mini-zapier/api run prisma:generate",
    "db:studio": "pnpm --filter @mini-zapier/api run prisma:studio"
  },
  "engines": {
    "node": ">=18"
  }
}
